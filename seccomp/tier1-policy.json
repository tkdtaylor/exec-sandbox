{
  "_comment": "exec-sandbox Tier-1 (bubblewrap) default-deny seccomp policy. Source of truth for seccomp/tier1.bpf (compiled offline by seccomp/build.sh via libseccomp's seccomp_export_bpf, byte-pinned by tier1.bpf.sha256). Modeled on the Docker/podman default profile: default action SCMP_ACT_ERRNO(EPERM); allowlist the common-case syscalls a payload shell + the proxy client (curl over a Unix socket) need; the dangerous-by-default family is denied implicitly by the default action AND named explicitly in deny[] as the documented, tested-against deny set. NO Go third-party runtime dependency: Go only open(2)s the resulting blob (stdlib os + crypto/sha256). See ADR 016.",
  "defaultAction": "SCMP_ACT_ERRNO",
  "defaultErrno": "EPERM",
  "arch": "x86_64",
  "deny": [
    "keyctl",
    "add_key",
    "request_key",
    "ptrace",
    "process_vm_readv",
    "process_vm_writev",
    "userfaultfd",
    "bpf",
    "perf_event_open",
    "mount",
    "umount2",
    "pivot_root",
    "kexec_load",
    "kexec_file_load",
    "init_module",
    "finit_module",
    "delete_module",
    "swapon",
    "swapoff",
    "reboot",
    "settimeofday",
    "clock_settime",
    "acct",
    "quotactl",
    "nfsservctl",
    "open_by_handle_at",
    "name_to_handle_at"
  ],
  "allow": [
    "read", "write", "readv", "writev", "pread64", "pwrite64", "preadv", "pwritev", "preadv2", "pwritev2",
    "open", "openat", "openat2", "close", "close_range", "creat",
    "stat", "fstat", "lstat", "newfstatat", "statx", "fstatfs", "statfs",
    "lseek", "fcntl", "flock", "fsync", "fdatasync", "ftruncate", "truncate",
    "getdents", "getdents64", "readlink", "readlinkat",
    "access", "faccessat", "faccessat2",
    "dup", "dup2", "dup3", "pipe", "pipe2", "poll", "ppoll", "select", "pselect6",
    "epoll_create", "epoll_create1", "epoll_ctl", "epoll_wait", "epoll_pwait", "epoll_pwait2",
    "eventfd", "eventfd2", "signalfd", "signalfd4", "timerfd_create", "timerfd_settime", "timerfd_gettime",
    "mmap", "munmap", "mremap", "mprotect", "madvise", "mlock", "munlock", "mlock2", "brk", "msync",
    "rt_sigaction", "rt_sigprocmask", "rt_sigreturn", "rt_sigpending", "rt_sigsuspend", "rt_sigtimedwait", "sigaltstack",
    "kill", "tgkill", "tkill", "rt_sigqueueinfo", "rt_tgsigqueueinfo", "pause",
    "clone", "clone3", "fork", "vfork", "execve", "execveat", "exit", "exit_group", "wait4", "waitid",
    "getpid", "getppid", "gettid", "getuid", "geteuid", "getgid", "getegid", "getresuid", "getresgid",
    "getpgrp", "getpgid", "getsid", "setpgid", "setsid",
    "getgroups", "setgroups", "getrlimit", "setrlimit", "prlimit64", "getrusage",
    "getcwd", "chdir", "fchdir", "mkdir", "mkdirat", "rmdir", "rename", "renameat", "renameat2",
    "link", "linkat", "unlink", "unlinkat", "symlink", "symlinkat",
    "chmod", "fchmod", "fchmodat", "chown", "fchown", "lchown", "fchownat", "umask",
    "utime", "utimes", "futimesat", "utimensat",
    "socket", "socketpair", "connect", "accept", "accept4", "bind", "listen",
    "getsockname", "getpeername", "getsockopt", "setsockopt", "sendto", "recvfrom", "sendmsg", "recvmsg", "shutdown", "sendmmsg", "recvmmsg",
    "uname", "sysinfo", "getrandom", "gettimeofday", "clock_gettime", "clock_getres", "clock_nanosleep", "nanosleep", "times",
    "sched_yield", "sched_getaffinity", "sched_setaffinity", "sched_getparam", "sched_getscheduler", "sched_get_priority_max", "sched_get_priority_min",
    "set_tid_address", "set_robust_list", "get_robust_list", "futex", "futex_waitv",
    "arch_prctl", "prctl", "rseq", "membarrier", "restart_syscall",
    "ioctl", "fadvise64", "sync", "syncfs", "fallocate", "memfd_create",
    "splice", "tee", "vmsplice", "copy_file_range", "sendfile",
    "setuid", "setgid", "setreuid", "setregid", "setresuid", "setresgid", "setfsuid", "setfsgid",
    "capget", "capset", "personality",
    "getpriority", "setpriority", "getcpu", "getitimer", "setitimer", "alarm",
    "inotify_init", "inotify_init1", "inotify_add_watch", "inotify_rm_watch",
    "mknod", "mknodat", "getxattr", "lgetxattr", "fgetxattr", "listxattr", "llistxattr", "flistxattr", "setxattr", "lsetxattr", "fsetxattr", "removexattr", "lremovexattr", "fremovexattr"
  ]
}
