#!/bin/sh
# SPDX-License-Identifier: Apache-2.0
#
# Guest PID 1 (init=/sbin/init) for the exec-sandbox Firecracker Tier-3 microVM.
#
# Responsibilities (kept minimal — this is part of the TCB baked into the read-only base):
#   1. mount the pseudo-filesystems the payload needs (/proc, /sys, /dev/pts, /tmp),
#   2. start the trusted vsock->/proxy.sock shim so the payload's egress contract is unchanged
#      across tiers (it always talks to /proxy.sock; the shim forwards bytes over vsock to the host
#      EgressProxy — no NIC, no in-guest egress decision),
#   3. mount the per-run WRITABLE payload drive (/dev/vdb) read-only and run /usr/bin/sh /payload.sh,
#   4. emit the guest's exit code on the serial console as a sentinel the host launcher parses,
#   5. power the microVM off (reboot=k panic=1 -> firecracker exits) so no guest outlives the run.
#
# The untrusted payload is NEVER baked into this read-only base — it arrives on /dev/vdb, a separate
# drive the host populates per run. The base digest is therefore stable across runs (scan once, pin
# once, reset for free).

set -u

# Pseudo-filesystems. The root drive is mounted READ-ONLY, so every writable surface the guest
# needs (/run for the shim socket + payload mount point, /tmp scratch) is a tmpfs.
mount -t proc     proc     /proc    2>/dev/null
mount -t sysfs    sysfs    /sys     2>/dev/null
mount -t devtmpfs devtmpfs /dev     2>/dev/null
mkdir -p /dev/pts
mount -t devpts   devpts   /dev/pts 2>/dev/null
mount -t tmpfs    tmpfs    /tmp     2>/dev/null
mount -t tmpfs    tmpfs    /run     2>/dev/null

# Start the dumb vsock->/proxy.sock shim (part of the TCB; see guest/rootfs/shim/main.go). The
# read-only root cannot host a socket, so the shim listens on /run/proxy.sock (writable tmpfs); the
# base ships /proxy.sock as a symlink to /run/proxy.sock, so the payload's contract is unchanged —
# it always talks to /proxy.sock, which resolves to the live socket.
/sbin/guest-proxy-shim /run/proxy.sock &

# The per-run payload arrives on /dev/vdb (a separate writable drive the host populates), mounted
# READ-ONLY here: the read-only base never bakes in the untrusted payload. Mount at /run/payload.
mkdir -p /run/payload
PAYLOAD=/payload.sh
if [ -b /dev/vdb ]; then
	if mount -o ro /dev/vdb /run/payload 2>/dev/null && [ -f /run/payload/payload.sh ]; then
		PAYLOAD=/run/payload/payload.sh
	fi
fi

# /work is the SINGLE writable surface (ADR 004 / F-006), presented on /dev/vdc — a writable ext4
# drive the host seeds from run.workdir (copy-in) and copies back at teardown (debugfs copy-out,
# unprivileged; ADR 010 Q2). Mount it READ-WRITE at /work; the payload's cwd is /work (set on the
# exec below) so a bare `out.txt` write lands on the writable surface and persists to the host
# workdir. When no /work drive is present (run.workdir == "") the mount is simply skipped and the
# payload runs from /run/payload as before — byte-for-byte the task-015 boot shape.
# /work exists in the read-only base as an empty mountpoint (build.sh creates it) — init cannot mkdir
# it at boot since the root is read-only.
WORKDIR=""
if [ -b /dev/vdc ]; then
	if mount /dev/vdc /work 2>/dev/null; then
		WORKDIR=/work
	fi
fi

# FileRead surfaces (ADR 005 / F-007): each validated FileRead path is a SEPARATE read-only ext4
# drive (/dev/vdd, /dev/vde, …); the host emits the device->mountpoint mapping on the trusted kernel
# cmdline as `exec_sandbox.fileread=/dev/vdd:/host/path,...`. Mount each device READ-ONLY and expose
# its single seeded entry at the SAME absolute host path the payload would use (mirroring bwrap's
# --ro-bind <p> <p>). A guest write fails (the drive is read-only at the virtio layer) and the host
# file is never touched. Absent arg => no FileRead mounts (the "zero = nothing" contract).
FILEREAD=""
for tok in $(cat /proc/cmdline 2>/dev/null); do
	case "$tok" in
		exec_sandbox.fileread=*) FILEREAD="${tok#exec_sandbox.fileread=}" ;;
	esac
done
if [ -n "$FILEREAD" ]; then
	OLDIFS="$IFS"
	IFS=','
	for pair in $FILEREAD; do
		dev="${pair%%:*}"
		dst="${pair#*:}"
		# Skip malformed pairs (no device or no path).
		[ -n "$dev" ] && [ -n "$dst" ] || continue
		[ -b "$dev" ] || continue
		# Mount the read-only drive on a tmpfs-backed staging mountpoint (the root is read-only, so the
		# staging point lives under /run). The drive is is_read_only:true at the virtio layer, so a
		# write to anything it backs fails regardless of the mount flags (F-007 enforced structurally).
		mp="/run/fileread${dst}"
		mkdir -p "$mp" 2>/dev/null
		mount -o ro "$dev" "$mp" 2>/dev/null || continue
		base="${dst##*/}"
		parent="${dst%/*}"
		[ -n "$parent" ] || parent=/
		# Recreate the host path inside the guest. Parents under a tmpfs (/tmp, /run) or an existing
		# rootfs dir are creatable; mkdir best-efforts otherwise. The seeded entry is then bind-mounted
		# (read-only) onto the host path so the payload reads it at the SAME absolute path it would on
		# the host (mirroring bwrap --ro-bind <p> <p>).
		mkdir -p "$parent" 2>/dev/null
		if [ -d "$mp/$base" ]; then
			mkdir -p "$dst" 2>/dev/null
			mount --bind "$mp/$base" "$dst" 2>/dev/null
			mount -o remount,ro,bind "$dst" 2>/dev/null
		elif [ -f "$mp/$base" ]; then
			: > "$dst" 2>/dev/null
			mount --bind "$mp/$base" "$dst" 2>/dev/null
			mount -o remount,ro,bind "$dst" 2>/dev/null
		fi
	done
	IFS="$OLDIFS"
fi

# pids -> in-guest RLIMIT_NPROC. The host emits `exec_sandbox.nproc=N` on the kernel cmdline (only
# when profile.limits.pids > 0); parse it here and apply it as an RLIMIT_NPROC ceiling BEFORE running
# the payload, so a fork bomb in the payload hits the cap. The guest owns its own pid space, so this
# rlimit must be set inside the guest (analogous to the host-side prlimit --nproc wrap on the other
# tiers). Absent arg => no cap (the "zero = no limit" contract).
NPROC=""
for tok in $(cat /proc/cmdline 2>/dev/null); do
	case "$tok" in
		exec_sandbox.nproc=*) NPROC="${tok#exec_sandbox.nproc=}" ;;
	esac
done
# Validate: digits only, non-empty.
case "$NPROC" in
	"" | *[!0-9]*) NPROC="" ;;
esac

# Run the payload as /usr/bin/sh /payload.sh — the same entry point as every other tier.
#
# When an NPROC cap is requested we MUST run the payload as an UNPRIVILEGED user: the Linux kernel
# does NOT enforce RLIMIT_NPROC for a privileged process (one holding CAP_SYS_ADMIN/CAP_SYS_RESOURCE
# — which a uid-0 guest process does), so a root payload would sail past the cap (verified: a fork
# bomb under uid 0 never hits the cap). So we (1) set RLIMIT_NPROC=N with `ulimit -u` — inherited
# across the exec below — then (2) `setpriv --reuid 65534 --regid 65534 --clear-groups` to drop to
# nobody and clear ALL capabilities, then exec the payload. As uid 65534 (with no caps) the inherited
# RLIMIT_NPROC genuinely bites — the in-guest analogue of the per-sandbox userns NPROC under
# bubblewrap. The payload reaches /proxy.sock as before (the shim's socket is world-accessible on the
# /run tmpfs).
#
# With no NPROC cap the payload runs exactly as task 015 (root, /usr/bin/sh /payload.sh) —
# byte-for-byte the prior boot, so the egress/boot E2E tests are unchanged.
# /usr/bin/setpriv is the util-linux binary (supports --reuid/--regid/--clear-groups); the busybox
# applet at /bin/setpriv does NOT, so the absolute path is used to bypass PATH (which has /bin first).
# cwd: when a /work surface is present the payload runs FROM /work (cwd=/work), so a bare relative
# write (`echo > out.txt`) lands on the single writable surface and persists to the host workdir
# (ADR 004). When 65534 owns the run (NPROC path) /work must be writable by that uid, so it is made
# world-writable first (the drive is per-run and discarded after copy-out). With no /work surface the
# cwd is left at / as before.
if [ -n "$WORKDIR" ]; then
	chmod 0777 /work 2>/dev/null
	cd /work 2>/dev/null
fi

if [ -n "$NPROC" ] && [ -x /usr/bin/setpriv ]; then
	chmod 0777 /run 2>/dev/null
	ulimit -u "$NPROC" 2>/dev/null
	/usr/bin/setpriv --reuid 65534 --regid 65534 --clear-groups --no-new-privs --inh-caps=-all \
		/usr/bin/sh "$PAYLOAD"
	code=$?
else
	/usr/bin/sh "$PAYLOAD"
	code=$?
fi

# Emit the exit-code sentinel the host launcher (fc-launch) parses off the serial console. The
# guest's exit code is NOT the firecracker process exit code, so the launcher reconstructs it from
# this line and exits with it, keeping Run()'s host-side exit-code mapping unchanged.
echo "__EXEC_SANDBOX_EXIT__ ${code}"

# Power off: reboot=k panic=1 makes a reboot terminate firecracker cleanly.
sync
reboot -f 2>/dev/null
# If reboot is unavailable, trigger a kernel reset via the sysrq/exit path.
echo o > /proc/sysrq-trigger 2>/dev/null
halt -f 2>/dev/null
# Last resort: loop so PID 1 never exits with a panic before the sentinel is flushed.
while true; do sleep 1; done
